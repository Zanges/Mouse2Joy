<Application x:Class="Mouse2Joy.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tt="clr-namespace:Mouse2Joy.UI.Tooltips;assembly=Mouse2Joy.UI"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Typed template for structured tooltip content. Renders Typical
             first (italic, dim) so the at-a-glance answer is closest to
             the input being hovered, then Description, then Advice. Null
             sections collapse via DataTrigger. See
             ai-docs/implementations/TOOLTIP_AUTO_WRAP.md. -->
        <DataTemplate DataType="{x:Type tt:TooltipContent}">
            <StackPanel>
                <TextBlock Text="{Binding Typical, StringFormat='Typical {0}'}"
                           FontStyle="Italic" Opacity="0.7" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Typical}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding Advice}" TextWrapping="Wrap" Margin="0,8,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Advice}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Plain-string tooltip template: wraps text inside the 320px cap. -->
        <DataTemplate x:Key="StringTooltipTemplate">
            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
        </DataTemplate>

        <!-- Selector: strings → wrapping template above; TooltipContent →
             falls through to the DataType-keyed template at top. -->
        <tt:TooltipTemplateSelector x:Key="TooltipTemplateSelector"
                                    StringTemplate="{StaticResource StringTooltipTemplate}"/>

        <!-- App-wide ToolTip style. Caps width at 320px and routes content
             through the selector so strings get wrapped while TooltipContent
             records get their typed sectioned template. The selector is
             load-bearing: applying a ContentTemplate directly would clobber
             the typed DataTemplate lookup. -->
        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="MaxWidth" Value="320"/>
            <Setter Property="ContentTemplateSelector" Value="{StaticResource TooltipTemplateSelector}"/>
        </Style>
    </Application.Resources>
</Application>
