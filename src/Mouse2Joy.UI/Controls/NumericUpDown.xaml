<UserControl x:Class="Mouse2Joy.UI.Controls.NumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FocusManager.IsFocusScope="False">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="Tb"
                 Grid.Column="0"
                 VerticalContentAlignment="Center"
                 PreviewKeyDown="OnTextBoxKeyDown"
                 PreviewMouseWheel="OnMouseWheel"
                 LostFocus="OnTextBoxLostFocus"/>
        <Grid Grid.Column="1" Margin="2,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <RepeatButton x:Name="UpBtn" Grid.Row="0" Content="▲"
                          FontSize="8" Padding="0" Width="20" MinHeight="0"
                          Delay="200" Interval="50"
                          Click="OnUpClick"/>
            <RepeatButton x:Name="DownBtn" Grid.Row="1" Content="▼"
                          FontSize="8" Padding="0" Width="20" MinHeight="0"
                          Delay="200" Interval="50"
                          Click="OnDownClick"/>
        </Grid>
    </Grid>
</UserControl>
