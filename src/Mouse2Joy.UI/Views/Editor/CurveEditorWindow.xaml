<Window x:Class="Mouse2Joy.UI.Views.Editor.CurveEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Mouse2Joy.UI.Controls"
        Title="Curve Editor"
        Width="640" Height="560" MinWidth="480" MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The interactive canvas takes all remaining space. -->
        <Border Grid.Row="0" BorderBrush="#2B2B30" BorderThickness="1">
            <c:CurveEditorCanvas x:Name="Canvas"
                                 Points="{Binding Points, Mode=TwoWay}"
                                 Symmetric="{Binding Symmetric, Mode=OneWay}"/>
        </Border>

        <!-- Symmetric checkbox + point count -->
        <Grid Grid.Row="1" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="Symmetric (mirror negative side)"
                      IsChecked="{Binding Symmetric, Mode=TwoWay}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="Points" Margin="20,0,8,0" VerticalAlignment="Center"/>
            <Slider Grid.Column="3" Minimum="2" Maximum="7" SmallChange="1"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding PointCount, Mode=TwoWay}"
                    VerticalAlignment="Center"/>
            <TextBox Grid.Column="4" Text="{Binding PointCount, UpdateSourceTrigger=LostFocus}"
                     Margin="6,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Hint -->
        <TextBlock Grid.Row="2" Margin="0,4,0,8" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                   Text="Drag points to move. Click empty area to add. Right-click a point to remove. Hold Shift to snap to 0.05 grid."/>

        <!-- Close button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" IsDefault="True" IsCancel="True" Click="OnCloseClick"
                    Padding="16,4" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
