<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:vm="clr-namespace:Mouse2Joy.UI.ViewModels.Editor"
                    xmlns:m="clr-namespace:Mouse2Joy.Persistence.Models;assembly=Mouse2Joy.Persistence"
                    xmlns:tt="clr-namespace:Mouse2Joy.UI.Tooltips">

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- Stick Dynamics: mode picker + 1 or 2 params depending on mode -->
    <DataTemplate DataType="{x:Type vm:StickDynamicsProxy}">
        <StackPanel>
            <TextBlock Text="Mode" Margin="0,0,0,2"/>
            <ComboBox SelectedValue="{Binding Mode, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" HorizontalAlignment="Left" Margin="0,0,0,8">
                <ComboBoxItem Content="Velocity (decay)" Tag="{x:Static m:StickDynamicsMode.Velocity}"/>
                <ComboBoxItem Content="Accumulator (spring)" Tag="{x:Static m:StickDynamicsMode.Accumulator}"/>
                <ComboBoxItem Content="Persistent (no recenter)" Tag="{x:Static m:StickDynamicsMode.Persistent}"/>
            </ComboBox>

            <TextBlock Text="{Binding Param1Label}" Margin="0,0,0,2"/>
            <TextBox Text="{Binding Param1, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8"/>

            <StackPanel Visibility="{Binding Param2Visible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding Param2Label}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Param2, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Width="120" HorizontalAlignment="Left"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- Digital → Scalar -->
    <DataTemplate DataType="{x:Type vm:DigitalToScalarProxy}">
        <StackPanel>
            <TextBlock Text="On value (input = pressed)"/>
            <TextBox Text="{Binding OnValue, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <TextBlock Text="Off value (input = released)"/>
            <TextBox Text="{Binding OffValue, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Width="120" HorizontalAlignment="Left"/>
        </StackPanel>
    </DataTemplate>

    <!-- Threshold (Scalar → Digital) -->
    <DataTemplate DataType="{x:Type vm:ScalarToDigitalThresholdProxy}">
        <StackPanel>
            <TextBlock Text="Threshold (|input| above this fires)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="1" SmallChange="0.05" Value="{Binding Threshold, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Threshold, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Sensitivity -->
    <DataTemplate DataType="{x:Type vm:SensitivityProxy}">
        <StackPanel>
            <TextBlock Text="Multiplier"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.05" Maximum="5" SmallChange="0.05" Value="{Binding Multiplier, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Multiplier, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Inner Deadzone -->
    <DataTemplate DataType="{x:Type vm:InnerDeadzoneProxy}">
        <StackPanel>
            <TextBlock Text="Threshold (|input| below this becomes 0)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="0.95" SmallChange="0.01" Value="{Binding Threshold, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Threshold, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Outer Saturation -->
    <DataTemplate DataType="{x:Type vm:OuterSaturationProxy}">
        <StackPanel>
            <TextBlock Text="Threshold (|input| above 1 - this becomes ±1)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="0.95" SmallChange="0.01" Value="{Binding Threshold, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Threshold, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Response Curve -->
    <DataTemplate DataType="{x:Type vm:ResponseCurveProxy}">
        <StackPanel>
            <TextBlock Text="Exponent"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.25" Maximum="4" SmallChange="0.05" Value="{Binding Exponent, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Exponent, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Exponent &lt; 1 boosts small inputs (concave). &gt; 1 attenuates them (convex)."/>
        </StackPanel>
    </DataTemplate>

    <!-- Segmented Response Curve -->
    <DataTemplate DataType="{x:Type vm:SegmentedResponseCurveProxy}">
        <StackPanel>
            <TextBlock Text="Region (which segment is curved)"/>
            <ComboBox SelectedValue="{Binding Region, Mode=TwoWay}" SelectedValuePath="Tag" Width="220" HorizontalAlignment="Left" Margin="0,0,0,8">
                <ComboBoxItem Content="Above threshold (linear → curved)" Tag="{x:Static m:SegmentedCurveRegion.AboveThreshold}"/>
                <ComboBoxItem Content="Below threshold (curved → linear)" Tag="{x:Static m:SegmentedCurveRegion.BelowThreshold}"/>
            </ComboBox>

            <TextBlock Text="Threshold (|input| where linear and curved segments meet)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.05" Maximum="0.95" SmallChange="0.01" Value="{Binding Threshold, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Threshold, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Exponent (applied inside the curved segment)" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.25" Maximum="4" SmallChange="0.05" Value="{Binding Exponent, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Exponent, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="The curved segment is remapped to its own [0, 1] range, so output is continuous at the threshold. Exponent &lt; 1 boosts (concave); &gt; 1 attenuates (convex). The non-curved segment is linear passthrough."/>
        </StackPanel>
    </DataTemplate>

    <!-- Ramp Up -->
    <DataTemplate DataType="{x:Type vm:RampUpProxy}">
        <StackPanel>
            <TextBlock Text="Seconds to full deflection"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding SecondsToFull, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding SecondsToFull, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Limits how fast |output| can grow. Decreases pass through unchanged."/>
        </StackPanel>
    </DataTemplate>

    <!-- Ramp Down -->
    <DataTemplate DataType="{x:Type vm:RampDownProxy}">
        <StackPanel>
            <TextBlock Text="Seconds from full deflection back to 0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding SecondsFromFull, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding SecondsFromFull, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Limits how fast |output| can shrink. Increases pass through unchanged."/>
        </StackPanel>
    </DataTemplate>

    <!-- Limiter (asymmetric per-side maxima) -->
    <DataTemplate DataType="{x:Type vm:LimiterProxy}">
        <StackPanel>
            <TextBlock Text="Max positive (cap on x &gt; 0)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding MaxPositive, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding MaxPositive, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Text="Max negative (cap on x &lt; 0)" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding MaxNegative, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding MaxNegative, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Hard-clamps |output| to per-side maxima. Both fields are non-negative magnitudes; set MaxPositive=0 to block the positive direction entirely."/>
        </StackPanel>
    </DataTemplate>

    <!-- Smoothing (low-pass) -->
    <DataTemplate DataType="{x:Type vm:SmoothingProxy}">
        <StackPanel>
            <TextBlock Text="Time constant (seconds)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="0.5" SmallChange="0.01" Value="{Binding TimeConstantSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding TimeConstantSeconds, StringFormat=F3, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Exponential moving average. Smaller = snappier (less smoothing); larger = smoother but laggier. 0 = passthrough."/>
        </StackPanel>
    </DataTemplate>

    <!-- Auto-fire -->
    <DataTemplate DataType="{x:Type vm:AutoFireProxy}">
        <StackPanel>
            <TextBlock Text="Frequency (Hz)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="30" SmallChange="0.5" Value="{Binding Hz, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding Hz, StringFormat=F1, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="While the input is held, the output pulses true at this rate (50% duty cycle). 0 = passthrough."/>
        </StackPanel>
    </DataTemplate>

    <!-- Hold to Activate -->
    <DataTemplate DataType="{x:Type vm:HoldToActivateProxy}">
        <StackPanel>
            <TextBlock Text="Hold duration (seconds)"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding HoldSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding HoldSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>
            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Output goes true only after the input has been held continuously for this duration. Releasing the input resets the timer."/>
        </StackPanel>
    </DataTemplate>

    <!-- Tap -->
    <DataTemplate DataType="{x:Type vm:TapProxy}">
        <StackPanel>
            <TextBlock Text="Max hold (seconds) — release within this counts as a tap"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.05" Maximum="3" SmallChange="0.05" Value="{Binding MaxHoldSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding MaxHoldSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Pulse duration (seconds) — how long the output stays true after a tap" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding PulseSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding PulseSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <CheckBox IsChecked="{Binding WaitForHigherTaps, Mode=TwoWay}" Content="Wait for higher taps (avoid conflicts with multi-tap bindings)" Margin="0,12,0,0"/>

            <StackPanel Visibility="{Binding ConfirmWaitVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Confirm wait (seconds) — how long to wait after release before firing" Margin="0,8,0,0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="0.1" Maximum="2" SmallChange="0.05" Value="{Binding ConfirmWaitSeconds, Mode=TwoWay}"/>
                    <TextBox Grid.Column="1" Text="{Binding ConfirmWaitSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                           Text="When enabled: a long press (held past Max hold) ALSO disambiguates and fires through immediately as a sustained passthrough. This adds intentional latency on single taps so sibling Multi-tap bindings can claim the input first."/>

                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                           Text="Tip: set Pulse duration to 0 to suppress the tap pulse entirely. The binding then ONLY fires while the input is held longer than Max hold (passthrough), giving you a 'hold-only' button that doesn't conflict with any sibling tap or multi-tap binding."/>
            </StackPanel>

            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Fires on release, not on press. If the input is held longer than Max hold, nothing fires — pair with Hold to Activate on a second binding to the same source for tap-vs-hold splitting."/>
        </StackPanel>
    </DataTemplate>

    <!-- Multi-tap -->
    <DataTemplate DataType="{x:Type vm:MultiTapProxy}">
        <StackPanel>
            <TextBlock Text="Tap count — number of taps required to fire"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="2" Maximum="6" SmallChange="1" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding TapCount, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding TapCount, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Window (seconds) — max time between successive taps" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.1" Maximum="2" SmallChange="0.05" Value="{Binding WindowSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding WindowSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Max hold per tap (seconds)" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.05" Maximum="3" SmallChange="0.05" Value="{Binding MaxHoldSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding MaxHoldSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Pulse duration (seconds)" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding PulseSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding PulseSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <CheckBox IsChecked="{Binding WaitForHigherTaps, Mode=TwoWay}" Content="Wait for higher taps (avoid conflicts with higher-count multi-tap bindings)" Margin="0,12,0,0"/>

            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Fires once after the configured number of taps land within the window. Each tap must individually be a release within Max hold per tap. With 'Wait for higher taps' enabled, also waits one more Window after the Nth tap to confirm no higher-count binding will claim the input."/>
        </StackPanel>
    </DataTemplate>

    <!-- Wait for Tap Resolution -->
    <DataTemplate DataType="{x:Type vm:WaitForTapResolutionProxy}">
        <StackPanel>
            <TextBlock Text="Max hold (seconds) — release within this is a tap; held longer is a passthrough press"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.05" Maximum="3" SmallChange="0.05" Value="{Binding MaxHoldSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding MaxHoldSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Wait (seconds) — how long to wait after release before firing" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0.1" Maximum="2" SmallChange="0.05" Value="{Binding WaitSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding WaitSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Text="Pulse duration (seconds)" Margin="0,8,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Grid.Column="0" Minimum="0" Maximum="3" SmallChange="0.05" Value="{Binding PulseSeconds, Mode=TwoWay}"/>
                <TextBox Grid.Column="1" Text="{Binding PulseSeconds, StringFormat=F2, UpdateSourceTrigger=LostFocus}" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Use this on a plain Key→Button binding when a sibling binding on the same source uses Multi-tap. The single press fires only after Wait elapses with no follow-up press, so a double-tap on a sibling binding takes priority. Press-and-hold (longer than Max hold) bypasses the wait and mirrors the input directly."/>

            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.7"
                       Text="Tip: set Pulse duration to 0 to suppress the tap pulse entirely. The binding then ONLY fires while the input is held longer than Max hold (passthrough), giving you a 'hold-only' button that doesn't conflict with any sibling tap or multi-tap binding."/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
